@startuml "clases"
!theme plain
hide circle
skinparam classAttributeIconSize 0
skinparam linetype ortho

' Añadimos espacio para evitar amontonamientos
skinparam nodesep 100
skinparam ranksep 100

class Usuario {
  nombre
  correo
  telefono
  ubicacion
}

class MensajeContacto {
  contenido
  fechaEnvio
  estadoLectura
}

class SolicitudAdopcion {
  motivoAdopcion
  condicionesOfrecidas
  estadoSolicitud
}

class Publicacion {
  tipoDePublicacion
  fechaDeRegistro
  estadoActual
  descripcion
}

class Mascota {
  nombre
  especie
  raza
  sexo
  fotos
  caracteristicasDistintivas
}

' =========================================
' RELACIONES DISTRIBUIDAS ESTRATÉGICAMENTE
' =========================================

' 1. Estructura principal vertical (Espina dorsal)
Usuario "1" --down-- "0..*" Publicacion : crea >
Publicacion "1" *--down-- "1..*" Mascota : contiene >

' 2. Módulo de Mensajería (Hacia la izquierda)
' Usamos una línea continua y otra punteada para distinguir envía/recibe
Usuario "1" -left- "0..*" MensajeContacto : envía >
Usuario "1" .-left- "0..*" MensajeContacto : recibe <

' 3. Módulo de Adopciones (Hacia la derecha)
Usuario "1" -right- "0..*" SolicitudAdopcion : aplica a >
SolicitudAdopcion "0..*" --down-- "1" Publicacion : pertenece a >

@enduml