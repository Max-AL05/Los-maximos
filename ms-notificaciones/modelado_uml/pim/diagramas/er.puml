@startuml "er"
!theme plain
hide circle

' =========================================
' CONFIGURACIÓN DE ESPACIOS (Evita amontonamiento)
' =========================================
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 120
skinparam padding 5

entity "CustomUser" as user {
  * id : AutoField <<PK>>
  --
  * email : EmailField <<UQ>>
  * nombre : CharField
  * apellido : CharField
  * fecha_nacimiento : DateField
  * genero : CharField
  * numero_celular : CharField
  * fecha_registro : DateTimeField
  * ultima_actualizacion : DateTimeField
}

entity "Mascota" as mascota {
  * id_mascota : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  * nombre : CharField
  * especie : CharField
  otra_especie : CharField
  raza : CharField
  * sexo : CharField
  * telefono : CharField
  fotos : ImageField
}

entity "MascotaEncontrada" as encontrada {
  * id_mascota_encontrada : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  id_adopcion_id : ForeignKey <<FK>>
  * nombre : CharField
  * especie : CharField
  * sexo : CharField
  * estado_publicacion : CharField
  fotos : ImageField
}

entity "MascotaAdopcion" as adopcion_m {
  * id_mascota_adopcion : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  * nombre : CharField
  * especie : CharField
  * edad : CharField
  * tamanio : CharField
  * sexo : CharField
  * descripcion : TextField
  * ubicacion : CharField
  * vacunado : BooleanField
  * esterilizado : BooleanField
  * amigableConMascotas : BooleanField
  * amigableConNinos : BooleanField
  foto : ImageField
  * contactoNombre : CharField
  * contactoEmail : EmailField
  * contactoTelefono : CharField
}

entity "Adopcion" as adopcion {
  * id_adopcion : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  mascota_adopcion_id : ForeignKey <<FK>>
  mascota_encontrada_id : ForeignKey <<FK>>
}

entity "Publicacion" as publicacion {
  * id_publicacion : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  * tipo : CharField
  * estado : CharField
  * contenido : TextField
  * reacciones : PositiveIntegerField
  * fecha_registro : DateTimeField
}

entity "Comentario" as comentario {
  * id_comentario : AutoField <<PK>>
  --
  * publicacion_id : ForeignKey <<FK>>
  * usuario_id : ForeignKey <<FK>>
  * contenido : TextField
  * fecha : DateTimeField
}

entity "Mensaje" as mensaje {
  * id_mensaje : AutoField <<PK>>
  --
  * emisor_id : ForeignKey <<FK>>
  * receptor_id : ForeignKey <<FK>>
  * contenido : TextField
  * fecha_envio : DateTimeField
  * leido : BooleanField
}

entity "Notificacion" as notificacion {
  * id_notificacion : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  * mensaje : CharField
  * leida : BooleanField
  * fecha : DateTimeField
}

entity "Reaccion" as reaccion {
  * id_reaccion : AutoField <<PK>>
  --
  * usuario_id : ForeignKey <<FK>>
  * publicacion_id : ForeignKey <<FK>>
  * tipo : CharField
  * fecha : DateTimeField
}

' =========================================
' RELACIONES DISTRIBUIDAS ESTRATÉGICAMENTE
' =========================================

' 1. Mandamos la parte social hacia la DERECHA del usuario
user ||-right-o{ publicacion : "crea"
user ||-right-o{ mensaje : "envía/recibe"
user ||-right-o{ notificacion : "recibe"

' 2. Mandamos las mascotas hacia ABAJO del usuario
user ||--down-o{ mascota : "registra"
user ||--down-o{ encontrada : "encuentra"
user ||--down-o{ adopcion_m : "pone en adopción"

' 3. Relaciones secundarias de Publicación (hacia abajo)
publicacion ||--down-o{ comentario : "tiene"
publicacion ||--down-o{ reaccion : "tiene"
user ||--o{ comentario : "escribe"
user ||--o{ reaccion : "reacciona"

' 4. Relaciones de Adopción
user ||--down-o{ adopcion : "gestiona"
adopcion }o-left-o| adopcion_m : "asociada a"
adopcion }o-left-o| encontrada : "asociada a"

' 5. Relaciones Many-to-Many (Líneas punteadas para no saturar)
publicacion }o..o{ mascota : "menciona"
publicacion }o..o{ encontrada : "menciona"
publicacion }o..o{ adopcion_m : "menciona"

@enduml