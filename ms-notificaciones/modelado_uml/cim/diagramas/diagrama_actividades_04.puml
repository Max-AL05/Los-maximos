@startuml "actividades_04"
skinparam monochrome true
skinparam shadowing false

title Publicación de Perfil de Adopción

start
:Seleccionar opción "Dar en Adopción";
:Ingresar datos básicos de la mascota\n(Nombre, Edad aproximada, Especie, Tamaño);

:Completar sección de Historial Clínico\n(Estado de vacunación, Esterilización);
:Describir perfil de comportamiento\n(Amigable con niños, interactúa con otras mascotas);
:Indicar necesidades médicas o de cuidado especial\n(Si aplica);

repeat
  :Cargar fotografías claras de la mascota;
backward: Solicitar ajuste por validación de imagen;
repeat while (¿Imágenes cumplen criterios?) is (No)
->Sí;

:Verificar y confirmar datos de contacto del refugio o rescatista;
:Confirmar creación del perfil de adopción;

partition "Procesamiento interno" {
  :Validar completitud de campos obligatorios;
  :Registrar entidad en la base de datos;
}

:Publicar perfil en el feed bajo la etiqueta "Adopción";
stop
@enduml