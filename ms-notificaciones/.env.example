# === Notificaciones (ms-notificaciones) ===

# Django
DJANGO_SECRET_KEY=cambia-esto-en-produccion
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Servidor
REST_PORT=8006
GRPC_PORT=50056

# Base de datos (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=agm_notif_db
DB_USER=agm_user
DB_PASSWORD=agm_password
DB_HOST=localhost
DB_PORT=5432

# JWT (compartido entre MS para validar tokens emitidos por MS-1)
JWT_SECRET_KEY=cambia-esto-en-produccion-jwt
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=7

# URLs gRPC de otros microservicios (host:puerto)
GRPC_AUTH_URL=ms-auth:50051
GRPC_PERIODOS_URL=ms-periodos:50052
GRPC_ALUMNOS_URL=ms-alumnos:50053
GRPC_CALIFICACIONES_URL=ms-calificaciones:50054
GRPC_ASISTENCIAS_URL=ms-asistencias:50055
GRPC_NOTIFICACIONES_URL=ms-notificaciones:50056
GRPC_REPORTES_URL=ms-reportes:50057

# CORS (orígenes permitidos para REST externo)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# SMTP – correo saliente (en dev usar consola)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=AGM <noreply@agm.buap.mx>
